---
interface Props {
	variant?: "primary" | "secondary";
	headline: string;
	description: string;
}

const { variant = "primary", headline, description } = Astro.props;

const bgClass = variant === "primary" ? "bg-background" : "bg-muted/30";
const accentClass = variant === "primary" ? "border-l-4 border-l-error" : "border-l-4 border-l-success";
---

<section class={`py-12 sm:py-16 md:py-20 lg:py-24 ${bgClass}`}>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl mx-auto">
			<!-- Headline -->
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-6 sm:mb-8">
				{headline}
			</h2>

			<!-- Description with accent border -->
			<p class={`text-lg sm:text-xl text-muted-foreground leading-relaxed ${accentClass} pl-6 sm:pl-8`}>
				{description}
			</p>
		</div>
	</div>
</section>
