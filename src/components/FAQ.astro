---
import { faq } from "@/lib/content";
import Accordion from "./starwind/accordion/Accordion.astro";
import AccordionContent from "./starwind/accordion/AccordionContent.astro";
import AccordionItem from "./starwind/accordion/AccordionItem.astro";
import AccordionTrigger from "./starwind/accordion/AccordionTrigger.astro";
---

<section id="faq" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-muted/30">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
				{faq.heading}
			</h2>
			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
				{faq.description}
			</p>
		</div>

		<!-- FAQ Accordion -->
		<div class="max-w-3xl mx-auto">
			<Accordion type="single" class="bg-card rounded-lg border border-border overflow-hidden">
				{
					faq.items.map((item, index) => (
						<AccordionItem value={`faq-${index}`}>
							<AccordionTrigger class="px-6 sm:px-8 hover:bg-muted/50">
								{item.question}
							</AccordionTrigger>
							<AccordionContent class="px-6 sm:px-8 text-muted-foreground leading-relaxed">
								{item.answer}
							</AccordionContent>
						</AccordionItem>
					))
				}
			</Accordion>
		</div>
	</div>
</section>
