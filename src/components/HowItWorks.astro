---
import { howItWorks } from "@/lib/content";
---

<section id="how-it-works" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-muted/30">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
				{howItWorks.heading}
			</h2>
			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
				{howItWorks.description}
			</p>
		</div>

		<!-- Steps Container -->
		<div class="grid gap-8 md:gap-6 grid-cols-1 md:grid-cols-3">
			{
				howItWorks.items.map((step, index) => (
					<div class="relative flex flex-col items-center md:items-start">
						<!-- Step Number Circle -->
						<div class="mb-6 shrink-0">
							<div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary text-primary-foreground text-2xl font-bold">
								{step.number}
							</div>
						</div>

						<!-- Step Content -->
						<div class="md:pr-6">
							<h3 class="text-xl sm:text-2xl font-bold text-foreground mb-3">
								{step.headline}
							</h3>
							<p class="text-muted-foreground leading-relaxed">
								{step.description}
							</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
