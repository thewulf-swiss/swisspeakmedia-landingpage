---
import { testimonials } from "@/lib/content";
import Card from "./starwind/card/Card.astro";
import CardContent from "./starwind/card/CardContent.astro";
---

<section id="testimonials" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-background">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
				{testimonials.heading}
			</h2>
			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
				{testimonials.description}
			</p>
		</div>

		<!-- Testimonials Grid -->
		<div class="grid gap-6 md:gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
			{testimonials.items.map((testimonial) => (
				<Card class="flex flex-col h-full">
					<!-- Quote -->
					<CardContent>
						<p class="italic text-foreground mb-6 leading-relaxed">
							"{testimonial.quote}"
						</p>
					</CardContent>

					<!-- Author Info -->
					<div class="mt-auto border-t border-border pt-6 px-6">
						<div class="flex items-center gap-4">
							<div class="h-10 w-10 shrink-0 text-primary-foreground bg-primary border-2 border-border rounded-full flex items-center justify-center text-xs font-bold">
								{testimonial.avatar}
							</div>
							<div class="min-w-0">
								<p class="font-semibold text-foreground truncate">
									{testimonial.author}
								</p>
								<p class="text-sm text-muted-foreground truncate">
									{testimonial.company}
								</p>
							</div>
						</div>
					</div>
				</Card>
			))}
		</div>
	</div>
</section>
