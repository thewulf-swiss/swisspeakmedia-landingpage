---
import Button from "./starwind/button/Button.astro";
import Logo from "./Logo.astro";
import { header } from "@/lib/content";

interface Props {
	class?: string;
}

const { navLinks, name } = header;
const { class: className } = Astro.props;
---

<header
	class={`sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur supports-backdrop-filter:bg-background/60 ${className || ""}`}
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="flex h-16 items-center justify-between md:h-20">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-2 font-bold text-lg md:text-xl">
				<Logo />
				<span class="hidden sm:inline">{name}</span>
			</a>

			<!-- Navigation Links -->
			<nav class="hidden md:flex items-center gap-8">
				{
					navLinks.map((link) => (
						<a
							href={link.href.startsWith("#") ? `/${link.href}` : link.href}
							class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
						>
							{link.label}
						</a>
					))
				}
			</nav>

			<!-- Mobile Menu Button -->
			<button
				id="mobile-menu-btn"
				class="inline-flex md:hidden items-center justify-center rounded-md p-2 text-foreground hover:bg-muted"
				aria-label="Toggle menu"
				aria-controls="mobile-menu"
				aria-expanded="false"
			>
				<svg
					class="h-6 w-6"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M4 6h16M4 12h16M4 18h16"
					></path>
				</svg>
			</button>

			<!-- CTA Button (Desktop) -->
			<div class="hidden sm:flex">
				<Button
					variant="primary"
					href={header.cta.href.startsWith("#") ? `/${header.cta.href}` : header.cta.href}
				>
					{header.cta.label}
				</Button>
			</div>
		</div>

		<script>
			if (typeof window !== "undefined") {
				window.addEventListener("DOMContentLoaded", () => {
					const toggleButton = document.getElementById("mobile-menu-btn");
					const menu = document.getElementById("mobile-menu");

					if (!toggleButton) return;

					toggleButton.addEventListener("click", () => {
						const currentlyExpanded =
							toggleButton.getAttribute("aria-expanded") === "true";
						const nextExpanded = !currentlyExpanded;

						toggleButton.setAttribute("aria-expanded", String(nextExpanded));

						if (menu) {
							menu.setAttribute("aria-hidden", String(!nextExpanded));
						}
					});
				});
			}
		</script>

		<!-- Mobile Menu -->
		<nav id="mobile-menu" class="hidden overflow-hidden bg-background md:hidden">
			<div class="border-t border-border px-2 pb-3 pt-2 space-y-1">
				{
					navLinks.map((link) => (
						<a
							href={link.href.startsWith("#") ? `/${link.href}` : link.href}
							class="block rounded-md px-3 py-2 text-base font-medium text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
						>
							{link.label}
						</a>
					))
				}
				<div class="px-3 py-2">
					<Button
						variant="primary"
						href={header.cta.href.startsWith("#") ? `/${header.cta.href}` : header.cta.href}
						class="w-full justify-center"
					>
						{header.cta.label}
					</Button>
				</div>
			</div>
		</nav>
	</div>
</header>

<script>
	// Mobile menu toggle
	const menuBtn = document.getElementById("mobile-menu-btn");
	const mobileMenu = document.getElementById("mobile-menu");

	menuBtn?.addEventListener("click", () => {
		mobileMenu?.classList.toggle("hidden");
	});

	// Close menu when a link is clicked
	document.querySelectorAll("#mobile-menu a").forEach((link) => {
		link.addEventListener("click", () => {
			mobileMenu?.classList.add("hidden");
		});
	});

	// Dark mode toggle (optional, add to header)
	const html = document.documentElement;
	const isDarkMode = () => html.classList.contains("dark");
	
	// You can add a dark mode toggle button here if desired
	// For now, users can manually toggle via localStorage
</script>