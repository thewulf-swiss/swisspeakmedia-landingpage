---
import { footer, siteConfig } from "@/lib/content";
import Logo from "./Logo.astro";
import SocialIcon from "./SocialIcon.astro";

const { name, description } = siteConfig;
const { sections, copyright, social } = footer;
const { quickLinks, legal } = sections;
---

<footer class="border-t border-border bg-background py-12 sm:py-16">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Footer Content -->
		<div class="grid gap-8 mb-8 md:grid-cols-3">
			<!-- Brand Section -->
			<div class="flex flex-col items-start gap-4">
				<div class="flex gap-2 items-center">
					<Logo />
					<span class="font-bold">{name}</span>
				</div>
				<p class="text-sm text-muted-foreground max-w-xs">
					{description}
				</p>
			</div>

			<!-- Links Section -->
			<div class="flex flex-col gap-4">
				<h3 class="font-semibold text-foreground">{quickLinks.title}</h3>
				<nav class="flex flex-col gap-2">
					{
						quickLinks.links.map((link) => (
							<a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
								{link.label}
							</a>
						))
					}
				</nav>
			</div>

			<!-- Legal & Social Section -->
			<div class="flex flex-col gap-4">
				<h3 class="font-semibold text-foreground">{legal.title}</h3>
				<nav class="flex flex-col gap-2">
					{
						legal.links.map((link) => (
							<a
								href={link.href}
								class="text-sm text-muted-foreground hover:text-foreground transition-colors"
							>
								{link.label}
							</a>
						))
					}
				</nav>
			</div>
		</div>

		<!-- Divider -->
		<div class="border-t border-border my-8"></div>

		<!-- Bottom Section -->
		<div class="flex flex-col md:flex-row items-center justify-between gap-4">
			<!-- Copyright -->
			<p class="text-sm text-muted-foreground">
				{copyright}
			</p>

			<!-- Social Media Links (optional) -->
			<div class="flex gap-4">
				{
					social.map((socialItem) => (
						<SocialIcon social={socialItem} />
					))
				}
			</div>
			
		</div>
	</div>
</footer>
