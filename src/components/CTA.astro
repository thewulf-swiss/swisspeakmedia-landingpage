---
import { cta } from "@/lib/content";
import Button from "./starwind/button/Button.astro";

const { headline, description, button, disclaimer } = cta;
---

<section id="cta" class="relative py-12 sm:py-16 md:py-20 lg:py-24 overflow-hidden">
	<!-- Background gradient -->
	<div class="absolute inset-0 -z-10 bg-linear-to-r from-primary via-primary to-secondary opacity-10"></div>
	<div class="absolute inset-0 -z-10 bg-linear-to-t from-background to-transparent"></div>

	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="rounded-2xl border border-primary/20 bg-card/50 backdrop-blur-sm p-8 sm:p-12 md:p-16 text-center">
			<!-- Headline -->
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6 max-w-3xl mx-auto">
				{headline}
			</h2>

			<!-- Description -->
			<p class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-8 sm:mb-12 leading-relaxed">
				{description}
			</p>

			<!-- Email Signup Form or CTA Button -->
			<form 
				name="contact"	
				method="POST"
				data-netlify="true" 
				class="flex flex-col sm:flex-row gap-4 justify-center items-center max-w-lg mx-auto"
			>
				<input type="hidden" name="form-name" value="contact" />
				<input
					type="email"
					name="email"
					placeholder="hallo@swisspeakmedia.ch"
					class="flex-1 w-full px-4 py-3 rounded-md border border-input bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
					aria-label="Email address"
					required
				/>
				<Button type="submit" variant="primary" size="lg" class="whitespace-nowrap">
					{button.label}
				</Button>
			</form>

			<!-- Additional Info -->
			<p class="text-sm text-muted-foreground mt-6">
				{disclaimer}
			</p>
		</div>
	</div>
</section>
