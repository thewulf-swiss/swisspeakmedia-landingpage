---
import { cta } from "@/lib/content";
import Button from "./starwind/button/Button.astro";

const { headline, description, button, disclaimer } = cta;

// Deine Forminit-ID aus dem Dashboard
const forminitAction = "https://forminit.com/f/lbpmppn2cve";
---

<section id="cta" class="relative py-12 sm:py-16 md:py-20 lg:py-24 overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-linear-to-r from-primary via-primary to-secondary opacity-10"></div>
    <div class="absolute inset-0 -z-10 bg-linear-to-t from-background to-transparent"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-primary/20 bg-card/50 backdrop-blur-sm p-8 sm:p-12 md:p-16">
            <div class="text-center">
                <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6 max-w-3xl mx-auto">
                    {headline}
                </h2>
                <p class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-8 leading-relaxed">
                    {description}
                </p>
            </div>

            <form action={forminitAction} method="POST" class="mx-auto max-w-3xl">
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label for="name" class="mb-2 block text-sm font-medium text-foreground">Name *</label>
                        <input 
                            id="name"
                            name="fi-sender-fullName" 
                            type="text" 
                            required 
                            placeholder="Ihr Name" 
                            class="w-full rounded-md border border-input bg-background px-4 py-3 text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                            oninvalid="this.setCustomValidity('Bitte geben Sie Ihren Namen an.')"
                            oninput="this.setCustomValidity('')"
                        />
                    </div>

                    <div>
                        <label for="email" class="mb-2 block text-sm font-medium text-foreground">E-Mail *</label>
                        <input 
                            id="email"
                            name="fi-sender-email" 
                            type="email" 
                            required 
                            placeholder="name@firma.ch" 
                            class="w-full rounded-md border border-input bg-background px-4 py-3 text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                            oninvalid="this.setCustomValidity('Bitte geben Sie eine gültige E-Mail-Adresse ein.')"
                            oninput="this.setCustomValidity('')"
                        />
                    </div>

                    <div>
                        <label for="phone" class="mb-2 block text-sm font-medium text-foreground">Telefon</label>
                        <input 
                            id="phone"
                            name="fi-text-phone" 
                            type="text" 
                            placeholder="079 123 45 67" 
                            class="w-full rounded-md border border-input bg-background px-4 py-3 text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                        />
                    </div>

                    <div>
                        <label for="company" class="mb-2 block text-sm font-medium text-foreground">Firma</label>
                        <input 
                            id="company"
                            name="fi-text-company" 
                            type="text" 
                            placeholder="Ihre Firma" 
                            class="w-full rounded-md border border-input bg-background px-4 py-3 text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                        />
                    </div>
                </div>

                <div class="mt-4">
                    <label for="service" class="mb-2 block text-sm font-medium text-foreground">Worum geht es? *</label>
                    <select 
                        id="service"
                        name="fi-select-service" 
                        required 
                        class="w-full rounded-md border border-input bg-background px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                        oninvalid="this.setCustomValidity('Bitte wählen Sie ein Thema aus.')"
                        oninput="this.setCustomValidity('')"
                    >
                        <option value="">Bitte auswählen</option>
                        <option value="Neue Website">Neue Website erstellen</option>
                        <option value="Modernisierung">Website modernisieren</option>
                        <option value="SEO">SEO & Sichtbarkeit</option>
                        <option value="Beratung">Beratungsgespräch</option>
                    </select>
                </div>

                <div class="mt-4">
                    <label for="message" class="mb-2 block text-sm font-medium text-foreground">Kurzbeschreibung</label>
                    <textarea 
                        id="message"
                        name="fi-text-message" 
                        rows="4" 
                        placeholder="Beschreiben Sie kurz Ihr Projekt oder Ihr Ziel." 
                        class="w-full rounded-md border border-input bg-background px-4 py-3 text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                    ></textarea>
                </div>

                <label class="mt-5 flex gap-3 text-sm leading-relaxed text-muted-foreground">
                    <input 
                        type="checkbox" 
                        name="fi-checkbox-gdpr" 
                        required 
                        class="mt-1 h-4 w-4 rounded border-input" 
                        oninvalid="this.setCustomValidity('Bitte akzeptieren Sie die Datenschutzerklärung, um fortzufahren.')"
                        oninput="this.setCustomValidity('')"
                    />
                    <span>
                        Ich habe die <a href="/datenschutz" class="underline hover:text-foreground text-primary">Datenschutzerklärung</a> gelesen und bin damit einverstanden, dass meine Daten zur Bearbeitung meiner Anfrage verwendet werden.
                    </span>
                </label>

                <div class="mt-6 flex flex-col items-center gap-4">
                    <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto whitespace-nowrap">
                        {button.label}
                    </Button>
                    
                    <p class="text-center text-xs text-muted-foreground">
                        {disclaimer}
                    </p>
                </div>
            </form>
        </div>
    </div>
</section>