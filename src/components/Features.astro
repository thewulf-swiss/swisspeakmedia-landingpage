---
import { features } from "@/lib/content";
import Card from "./starwind/card/Card.astro";
import CardContent from "./starwind/card/CardContent.astro";
import CardHeader from "./starwind/card/CardHeader.astro";
import CardTitle from "./starwind/card/CardTitle.astro";
---

<section id="features" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-background">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
				{features.heading}
			</h2>
			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
				{features.description}
			</p>
		</div>

		<!-- Features Grid -->
		<div class="grid gap-6 md:gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
			{
				features.items.map((feature) => (
					<Card class="hover:shadow-lg hover:border-primary/50 transition-all duration-300">
						<CardHeader>
							<div class="text-4xl mb-4">{feature.icon}</div>
							<CardTitle>{feature.headline}</CardTitle>
						</CardHeader>
						<CardContent>
							<p class="text-muted-foreground leading-relaxed">
								{feature.description}
							</p>
						</CardContent>
					</Card>
				))
			}
		</div>
	</div>
</section>
