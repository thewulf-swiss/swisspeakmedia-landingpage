---
import { hero } from "@/lib/content";
import Button from "./starwind/button/Button.astro";
import heroImage from "@/assets/seo-webdesign-dashboard-schweiz.webp";
---

<section id="hero" class="relative overflow-hidden py-12 sm:py-16 md:py-20 lg:py-24">
	<div class="absolute inset-0 -z-10 bg-linear-to-b from-primary/5 to-background"></div>

	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-12 lg:gap-16 lg:grid-cols-2 items-center">
			<div class="flex flex-col gap-6 sm:gap-8">
				<h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight text-foreground">
					{hero.headline}
				</h1>

				<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed max-w-xl">
					{hero.subheadline}
				</p>

				<div class="flex flex-col sm:flex-row gap-4 pt-2">
					<Button variant="primary" size="lg" href={hero.primaryCta.href}>
						{hero.primaryCta.label}
					</Button>
					<Button variant="ghost" size="lg" href={hero.secondaryCta.href}>
						{hero.secondaryCta.label}
					</Button>
				</div>

				<div class="flex items-center gap-4 pt-4">
					<div class="flex -space-x-2">
						<div class="h-8 w-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-xs font-bold border-2 border-background">U</div>
						<div class="h-8 w-8 rounded-full bg-secondary text-secondary-foreground flex items-center justify-center text-xs font-bold border-2 border-background">V</div>
						<div class="h-8 w-8 rounded-full bg-info text-info-foreground flex items-center justify-center text-xs font-bold border-2 border-background">W</div>
					</div>
					<p class="text-sm text-muted-foreground">
						⚡ Schnell • 🔍 Sichtbar • 🤖 KI-optimiert
					</p>
				</div>
			</div>

			<!-- Hero Image -->
			<div class="relative aspect-[16/10] rounded-3xl overflow-hidden bg-white shadow-2xl border border-white/40 scale-105">
				<img
					src={heroImage.src}
					alt="Modernes SEO und Webdesign Dashboard für Unternehmen in der Schweiz"
					class="w-full h-full object-cover object-center"
					loading="eager"
				/>
			</div>
		</div>
	</div>
</section>