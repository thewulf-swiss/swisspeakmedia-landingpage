---
import CTA from "@/components/CTA.astro";
import Description from "@/components/Description.astro";
import FAQ from "@/components/FAQ.astro";
import Features from "@/components/Features.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import HowItWorks from "@/components/HowItWorks.astro";
import Testimonials from "@/components/Testimonials.astro";
import Layout from "@/layouts/Layout.astro";
import { problem, solution } from "@/lib/content";
---

<Layout>
	<Header />
	<Hero />
	<Description headline={problem.headline} description={problem.description} variant="primary" />
	<Description headline={solution.headline} description={solution.description} variant="secondary" />
	<Features />
	<HowItWorks />
	<Testimonials />
	<CTA />
	<FAQ />
	<Footer />
</Layout>
