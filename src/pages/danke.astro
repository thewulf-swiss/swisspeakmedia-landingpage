---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
	<Header />

	<main class="relative overflow-hidden py-24 sm:py-32">
		<!-- Background gradient -->
		<div class="absolute inset-0 -z-10 bg-linear-to-r from-primary via-primary to-secondary opacity-10"></div>
		<div class="absolute inset-0 -z-10 bg-linear-to-t from-background to-transparent"></div>

		<div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
			<p class="mb-4 text-sm font-semibold uppercase tracking-wide text-primary">
				Anfrage erfolgreich gesendet
			</p>

			<h1 class="mb-6 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
				Vielen Dank für Ihre Anfrage.
			</h1>

			<p class="mx-auto mb-8 max-w-2xl text-lg leading-relaxed text-muted-foreground">
				Ihre Nachricht wurde erfolgreich übermittelt. Wir prüfen Ihre Angaben und melden uns in der Regel innerhalb von 24 Stunden bei Ihnen.
			</p>

			<div class="mx-auto mb-10 max-w-2xl rounded-2xl border border-primary/20 bg-card/50 p-6 text-left shadow-sm backdrop-blur-sm">
				<h2 class="mb-4 text-xl font-semibold text-foreground">
					Was passiert als Nächstes?
				</h2>

				<ul class="space-y-3 text-muted-foreground">
					<li class="flex gap-3">
						<span class="text-primary">✓</span>
						<span>Wir schauen uns Ihre Anfrage und Ihre bestehende Website an, falls Sie eine angegeben haben.</span>
					</li>
					<li class="flex gap-3">
						<span class="text-primary">✓</span>
						<span>Sie erhalten eine ehrliche Ersteinschätzung zu Website, Sichtbarkeit und möglichen nächsten Schritten.</span>
					</li>
					<li class="flex gap-3">
						<span class="text-primary">✓</span>
						<span>Das Erstgespräch ist kostenlos und unverbindlich.</span>
					</li>
				</ul>
			</div>

			<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
				<a
					href="/"
					class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90"
				>
					Zurück zur Startseite
				</a>

				<a
					href="/#faq"
					class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold text-foreground transition hover:bg-muted"
				>
					Häufige Fragen ansehen
				</a>
			</div>
		</div>
	</main>

	<Footer />
</Layout>