<script is:inline>
  // Diese Funktion lädt das Cookie-Banner erst, wenn die Seite "Idle" ist
  function loadCookieBanner() {
    var script = document.createElement('script');
    script.id = 'cookieyes';
    script.type = 'text/javascript';
    script.src = 'https://cdn-cookieyes.com/client_data/a8f07d55c3f568697d7ad4a2fa04e68d/script.js';
    script.async = true;
    document.head.appendChild(script);
  }

  // Warte bis alles geladen ist, dann gib dem Bild 500ms Vorsprung
  window.addEventListener('load', () => {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => setTimeout(loadCookieBanner, 500));
    } else {
      setTimeout(loadCookieBanner, 1000);
    }
  });
</script>

