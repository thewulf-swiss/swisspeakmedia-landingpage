---
import { siteConfig } from "@/lib/content";
import "@/styles/starwind.css";

const { title, description, image } = siteConfig;

const baseURL = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, baseURL);
const ogImageURL = new URL(image, baseURL);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <script is:inline id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/a8f07d55c3f568697d7ad4a2fa04e68d/script.js"></script>
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />

        <link rel="icon" type="image/svg+xml" href="/launch.svg" />
        <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
        <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

        {import.meta.env.DEV && <meta name="robots" content="noindex, nofollow" />}

        <script is:inline>
            const isDark =
                localStorage.getItem("theme") === "dark" ||
                (!localStorage.getItem("theme") && window.matchMedia("(prefers-color-scheme: dark)").matches);
            if (isDark) {
                document.documentElement.classList.add("dark");
            }
        </script>
    </head>
    <body class="bg-background text-foreground">
        <main>
            <slot />
        </main>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }

    :global(html) {
        scroll-behavior: smooth;
    }
</style>