---
import { siteConfig } from "@/lib/content";
import "@/styles/starwind.css";
import heroImage from "@/assets/seo-webdesign-dashboard-schweiz.webp";

const { title, description, image } = siteConfig;
const baseURL = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, baseURL);
const ogImageURL = new URL(image, baseURL);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <link rel="preload" as="image" href={heroImage.src} fetchpriority="high" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />

        <script is:inline>
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-N2FCR2L2');
        </script>

        <link rel="icon" type="image/svg+xml" href="/launch.svg" />
        <script is:inline>
            const isDark = localStorage.getItem("theme") === "dark" || (!localStorage.getItem("theme") && window.matchMedia("(prefers-color-scheme: dark)").matches);
            if (isDark) document.documentElement.classList.add("dark");
        </script>
    </head>
    <body class="bg-background text-foreground">
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N2FCR2L2" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        
        <main>
            <slot />
        </main>

        <script is:inline>
            (function() {
                var interactionEvents = ['mouseover', 'scroll', 'touchstart', 'click', 'mousemove'];
                var hasInjected = false;

                function injectNow() {
                    if (hasInjected) return;
                    hasInjected = true;
                    
                    console.log("Interaktion erkannt!");
                    var s = document.createElement('script');
                    s.id = 'cookieyes';
                    s.src = 'https://cdn-cookieyes.com/client_data/a8f07d55c3f568697d7ad4a2fa04e68d/script.js';
                    s.async = true;
                    document.body.appendChild(s);

                    interactionEvents.forEach(function(e) {
                        window.removeEventListener(e, injectNow);
                    });
                }

                // Wir starten den Check erst, wenn das Dokument bereit ist
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', function() {
                        interactionEvents.forEach(function(e) {
                            window.addEventListener(e, injectNow, { passive: true });
                        });
                    });
                } else {
                    interactionEvents.forEach(function(e) {
                        window.addEventListener(e, injectNow, { passive: true });
                    });
                }

                // Fallback für Bots (stark verzögert)
                setTimeout(injectNow, 12000);
            })();
        </script>
    </body>
</html>

<style>
    html, body { margin: 0; width: 100%; height: 100%; }
    :global(html) { scroll-behavior: smooth; }
</style>